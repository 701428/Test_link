# Copy this file to .env and fill in your Azure App Registration values

# Azure App Registration Client ID (required)
VITE_CLIENT_ID=your-client-id-here

# Azure Tenant ID — use "common" for multi-tenant / personal+work accounts
VITE_TENANT_ID=common

# Backend URL (default: localhost for local dev)
VITE_BACKEND_URL=http://localhost:8000
